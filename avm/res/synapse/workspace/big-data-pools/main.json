  "resources": {
    "workspace": {
      "existing": true,
      "type": "Microsoft.Synapse/workspaces",
      "apiVersion": "2021-06-01",
      "name": "[parameters('workspaceName')]"
    },
    "bigDataPool": {
      "type": "Microsoft.Synapse/workspaces/bigDataPools",
      "apiVersion": "2021-06-01",
      "name": "[format('{0}/{1}', parameters('workspaceName'), parameters('name'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "nodeSizeFamily": "[parameters('nodeSizeFamily')]",
        "nodeSize": "[parameters('nodeSize')]",
        "autoScale": "[if(not(empty(parameters('autoScale'))), createObject('enabled', tryGet(parameters('autoScale'), 'enabled'), 'maxNodeCount', json(tryGet(parameters('autoScale'), 'maxNodeCount')), 'minNodeCount', json(tryGet(parameters('autoScale'), 'minNodeCount'))), null())]",
        "nodeCount": "[if(empty(parameters('autoScale')), parameters('nodeCount'), null())]",
        "dynamicExecutorAllocation": "[if(not(empty(parameters('dynamicExecutorAllocation'))), createObject('enabled', tryGet(parameters('dynamicExecutorAllocation'), 'enabled'), 'maxExecutors', json(tryGet(parameters('dynamicExecutorAllocation'), 'maxExecutors')), 'minExecutors', json(tryGet(parameters('dynamicExecutorAllocation'), 'minExecutors'))), null())]",
        "autoPause": "[if(not(empty(parameters('autoPause'))), createObject('enabled', tryGet(parameters('autoPause'), 'enabled'), 'delayInMinutes', tryGet(parameters('autoPause'), 'delayInMinutes')), null())]",
        "sparkVersion": "[parameters('sparkVersion')]",
        "sessionLevelPackagesEnabled": "[parameters('sessionLevelPackagesEnabled')]",
        "cacheSize": "[parameters('cacheSize')]"
      }
    }
  },
  "outputs": {
    "name": {
      "type": "string",
      "metadata": {
        "description": "The name of the deployed Big Data Pool."
      },
      "value": "[parameters('name')]"
    },
    "resourceId": {
      "type": "string",
      "metadata": {
        "description": "The resource ID of the deployed Big Data Pool."
      },
      "value": "[resourceId('Microsoft.Synapse/workspaces/bigDataPools', parameters('workspaceName'), parameters('name'))]"
    },
    "resourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "The resource group of the deployed Big Data Pool."
      },
      "value": "[resourceGroup().name]"
    }
  }
