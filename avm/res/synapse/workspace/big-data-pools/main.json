  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Conditional. The name of the parent Synapse Workspace. Required if the template is used in a standalone deployment."
      }
    },
    "name": {
      "type": "string",
      "metadata": {
        "description": "Required. The name of the Big Data Pool."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Required. The geo-location where the resource lives."
      }
    },
    "tags": {
      "type": "object",
      "nullable": true,
      "metadata": {
        "description": "Optional. Tags of the resource."
      }
    },
    "autoPause": {
      "$ref": "#/definitions/autoPauseType",
      "defaultValue": {
        "delayInMinutes": 15,
        "enabled": true
      },
      "metadata": {
        "description": "Optional. Auto-pausing properties."
      }
    },
    "autoScale": {
      "$ref": "#/definitions/autoScaleType",
      "defaultValue": {
        "enabled": true,
        "maxNodeCount": "5",
        "minNodeCount": "3"
      },
      "metadata": {
        "description": "Optional. Auto-scaling properties."
      }
    },
    "cacheSize": {
      "type": "int",
      "defaultValue": 50,
      "minValue": 0,
      "maxValue": 100,
      "metadata": {
        "description": "Optional. The cache size."
      }
    },
    "dynamicExecutorAllocation": {
      "$ref": "#/definitions/dynamicExecutorAllocationType",
      "defaultValue": {
        "enabled": false,
        "maxExecutors": "2",
        "minExecutors": "1"
      },
      "metadata": {
        "description": "Optional. Dynamic Executor Allocation."
      }
    },
    "nodeCount": {
      "type": "int",
      "metadata": {
        "description": "Conditional. The number of nodes in the Big Data pool."
      }
    },
    "nodeSize": {
      "type": "string",
      "allowedValues": [
        "Large",
        "Medium",
        "None",
        "Small",
        "XLarge",
        "XXLarge",
        "XXXLarge"
      ],
      "metadata": {
        "description": "Required. The level of compute power that each node in the Big Data pool has."
      }
    },
    "nodeSizeFamily": {
      "type": "string",
      "allowedValues": [
        "HardwareAcceleratedFPGA",
        "HardwareAcceleratedGPU",
        "MemoryOptimized",
        "None"
      ],
      "metadata": {
        "description": "Required. The kind of nodes that the Big Data pool provides."
      }
    },
    "sessionLevelPackagesEnabled": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Optional. Whether session level packages enabled."
      }
    },
    "sparkVersion": {
      "type": "string",
      "nullable": true,
      "metadata": {
        "description": "Required. The Apache Spark version."
      }
    }
